    create or replace table `spatial-rig-493920-b5`.`fraud_dataset_stg_marts`.`fct_fraud_summary`
      
    partition by event_date
    cluster by type

    
    OPTIONS()
    as (
      

SELECT
    event_date,
    step,
    type,
    total_transactions,
    total_amount,
    fraud_count,
    flagged_fraud_count,

    SAFE_DIVIDE(fraud_count, total_transactions) AS fraud_rate,

    avg_amount,
